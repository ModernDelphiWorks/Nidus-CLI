unit XmlController;

interface

uses
  System.Evolution.ResultPair,
  XmlService,
  XmlInterface;

type
  TXmlController = class(TInterfacedObject, IXml)
  private
    FService: TXmlService;
  public
    constructor Create(const AReq: TXmlService);
    destructor Destroy; override;
    function Find: TResultPair<String, Exception>;
    function Insert(const AJson: String): TResultPair<String, Exception>;
    function Update(const AJson: String): TResultPair<String, Exception>;
    function Delete: TResultPair<String, Exception>;
  end;

implementation

uses
  nest4d.horse;

{ TXmlController }

constructor TXmlController.Create(const AReq: TXmlService);
begin
  FService := AReq;
end;

destructor TXmlController.Destroy;
begin
  FService.Free;
  inherited;
end;

function TXmlController.Delete: TResultPair<String, Exception>;
begin
  Result := FService.Delete;
end;

function TXmlController.Find: TResultPair<String, Exception>;
begin
  Result := FService.Find;
end;

function TXmlController.Insert(const AJson: String): TResultPair<String, Exception>;
begin
  Result := FService.Insert(AJson);
end;

function TXmlController.Update(const AJson: String): TResultPair<String, Exception>;
begin
  Result := FService.Update(AJson);
end;

end.
