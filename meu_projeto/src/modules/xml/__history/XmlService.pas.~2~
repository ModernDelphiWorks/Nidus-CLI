unit XmlService;

interface

uses
  SysUtils,
  System.Evolution.ResultPair,
  XmlRepository,
  XmlInterface;

type
  TXmlService = class(TInterfacedObject, I$mod)
  private
    FRepository: TXmlRepository;
  public
    constructor Create(const ARepository: TXmlRepository);
    destructor Destroy; override;
    function Find: TResultPair<String, Exception>;
    function Insert(const AJson: String): TResultPair<String, Exception>;
    function Update(const AJson: String): TResultPair<String, Exception>;
    function Delete: TResultPair<String, Exception>;
  end;

implementation

{ TXmlService }

constructor TXmlService.Create(const ARepository: TXmlRepository);
begin
  FRepository := ARepository;
end;

destructor TXmlService.Destroy;
begin
  FRepository.Free;
  inherited;
end;

function TXmlService.Delete: TResultPair<String, Exception>;
begin
  try
    Result.Success(FRepository.Delete);
  except
    on E: Exception do
      Result.Failure(E);
  end;
end;

function TXmlService.Find: TResultPair<String, Exception>;
begin
  try
    Result.Success(FRepository.Find);
  except
    on E: Exception do
      Result.Failure(E);
  end;
end;

function TXmlService.Insert(const AJson: String): TResultPair<String, Exception>;
begin
  try
    Result.Success(FRepository.Insert(AJson));
  except
    on E: Exception do
      Result.Failure(E);
  end;
end;

function TXmlService.Update(const AJson: String): TResultPair<String, Exception>;
begin
  try
    Result.Success(FRepository.Update(AJson));
  except
    on E: Exception do
      Result.Failure(E);
  end;
end;

end.
