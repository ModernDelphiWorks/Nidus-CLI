unit NfeController;

interface

uses
  System.Evolution.ResultPair,
  NfeService,
  NfeInterface;

type
  TNfeController = class(TInterfacedObject, INfe)
  private
    FService: TNfeService;
  public
    constructor Create(const AReq: TNfeService);
    destructor Destroy; override;
    function Find: TResultPair<String, Exception>;
    function Insert(const AJson: String): TResultPair<String, Exception>;
    function Update(const AJson: String): TResultPair<String, Exception>;
    function Delete: TResultPair<String, Exception>;
  end;

implementation

uses
  nest4d.horse;

{ TNfeController }

constructor TNfeController.Create(const AReq: TNfeService);
begin
  FService := AReq;
end;

destructor TNfeController.Destroy;
begin
  FService.Free;
  inherited;
end;

function TNfeController.Delete: TResultPair<String, Exception>;
begin
  Result := FService.Delete;
end;

function TNfeController.Find: TResultPair<String, Exception>;
begin
  Result := FService.Find;
end;

function TNfeController.Insert(const AJson: String): TResultPair<String, Exception>;
begin
  Result := FService.Insert(AJson);
end;

function TNfeController.Update(const AJson: String): TResultPair<String, Exception>;
begin
  Result := FService.Update(AJson);
end;

end.
