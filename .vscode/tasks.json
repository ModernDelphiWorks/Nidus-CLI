{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cargo build",
      "dependsOn": [
        "cargo build example"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "cargo build release",
      "dependsOn": [
        "cargo build example release"
      ]
    },
    {
      "label": "cargo build example",
      "type": "shell",
      "command": "cargo build",
      "args": [],
      "problemMatcher": [
        "$rustc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "cargo build example release",
      "type": "shell",
      "command": "cargo build --release",
      "args": [],
      "problemMatcher": [
        "$rustc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "prepare release (build only)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "echo 'Building release version...'; cargo build --release; if [ $? -eq 0 ]; then echo 'Release build successful!'; echo 'Executable location:'; find target/release -maxdepth 1 -type f; git status; else echo 'Build failed!'; fi"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": [
        "$rustc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}